# Environment configuration (dev/prod)
ENVIRONMENT=dev

# Production credentials
BOT_TOKEN=your_production_bot_token_here
TEAMUP_API_KEY=your_production_teamup_api_key_here
TEAMUP_CALENDAR_KEY=your_production_calendar_key_here
TEAMUP_CALENDAR_READER_KEY=your_production_reader_key_here
TEAMUP_SUBCALENDAR_ID=your_production_subcalendar_id_here

# Development credentials (optional, only needed when ENVIRONMENT=dev)
BOT_TOKEN_DEV=your_dev_bot_token_here
TEAMUP_API_KEY_DEV=your_dev_teamup_api_key_here
TEAMUP_CALENDAR_KEY_DEV=your_dev_calendar_key_here

# Common settings
ADMIN_ID=your_telegram_user_id_here
RA_QUERY_TEMPLATE_PATH=graphql_query_template.json

# Announcement updater configuration
# Telegram chat ID whose pinned weekly events message should be managed.
# Leave empty for local/dev sessions that should not auto-schedule pinned updates.
ANNOUNCEMENT_CHAT_ID=
ANNOUNCEMENT_INTERVAL_SECONDS=3600
ANNOUNCEMENT_FIRST_RUN_SECONDS=60

# Optional: Timezone Configuration (default: Europe/London)
CALENDAR_TIMEZONE=Europe/London

# Optional: Structured Logging (default: false)
# LOG_JSON_FORMAT=true
