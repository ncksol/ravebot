# Ravebot Environment Configuration
# Copy this file to .env and fill in your actual values
# WARNING: Never commit .env file with real credentials to version control!

# Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here

# Admin Configuration
# Option 1: Single admin (legacy)
# ADMIN_ID=123456789

# Option 2: Multiple admins (recommended)
ADMIN_IDS=123456789,987654321,456789123

# Language Configuration
# Supported: 'ru' (Russian, default), 'en' (English)
LANGUAGE=ru

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# RA Configuration
RA_QUERY_TEMPLATE_PATH=graphql_query_template.json

# Teamup Calendar Configuration
TEAMUP_API_KEY=your_teamup_api_key
TEAMUP_CALENDAR_KEY=your_calendar_key
TEAMUP_CALENDAR_READER_KEY=your_reader_key
TEAMUP_SUBCALENDAR_ID=your_subcalendar_id
